    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <joint_name>horizontal_rudder_front_left_joint</joint_name>
      <topic>/model/submarine/joint/horizontal_rudder_front_left/cmd_position</topic>
