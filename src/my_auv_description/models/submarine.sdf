      </visual>
      <collision name="hfrl_c">
        <geometry><box><size>0.1 0.2 0.005</size></box></geometry>
      </collision>
    </link>
    <joint name="horizontal_rudder_front_left_joint" type="revolute">
      <parent>body</parent><child>horizontal_rudder_front_left</child>
      <axis>
