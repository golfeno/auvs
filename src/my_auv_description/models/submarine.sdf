<?xml version="1.0" ?>
<sdf version="1.6">
  <model name="submarine">
    <pose>0 0 0 1.5707963267948966 1.5707963267948966 0</pose>

    <link name="body">
      <pose>0 0 0 0 1.5707963267948966 0</pose>
      <inertial>
        <pose>0 0 -0.02 0 0 0</pose>
        <mass>102</mass>
        <inertia><ixx>1.64</ixx><iyy>18.33</iyy><izz>18.33</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
        <fluid_added_mass><xx>5.8</xx><yy>116.0</yy><zz>116.0</zz><pp>0.7</pp><qq>0.5</qq><rr>0.5</rr></fluid_added_mass>
      </inertial>
