      <collision name="body_collision"><geometry><cylinder><radius>0.1666667</radius><length>1.3333333</length></cylinder></geometry></collision>
      <sensor name="imu_sensor" type="imu"><always_on>1</always_on><update_rate>100</update_rate><topic>/model/submarine/imu</topic></sensor>
      <sensor name="pressure_sensor" type="air_pressure"><always_on>1</always_on><update_rate>50</update_rate><topic>/sub_press</topic></sensor>
    </link>

