    <plugin filename="gz-sim-buoyancy-engine-system" name="gz::sim::systems::BuoyancyEngine"><link_name>ballast_1</link_name><min_volume>0.0</min_volume><max_volume>0.015</max_volume><neutral_volume>0.0075</neutral_volume><default_volume>0.0075</default_volume><max_inflation_rate>0.001</max_inflation_rate><fluid_density>1000</fluid_density><namespace>sub_ballast_1</namespace></plugin>
    <plugin filename="gz-sim-buoyancy-engine-system" name="gz::sim::systems::BuoyancyEngine"><link_name>ballast_2</link_name><min_volume>0.0</min_volume><max_volume>0.015</max_volume><neutral_volume>0.0075</neutral_volume><default_volume>0.0075</default_volume><max_inflation_rate>0.001</max_inflation_rate><fluid_density>1000</fluid_density><namespace>sub_ballast_2</namespace></plugin>
    <plugin filename="gz-sim-buoyancy-engine-system" name="gz::sim::systems::BuoyancyEngine"><link_name>ballast_3</link_name><min_volume>0.0</min_volume><max_volume>0.015</max_volume><neutral_volume>0.0075</neutral_volume><default_volume>0.0075</default_volume><max_inflation_rate>0.001</max_inflation_rate><fluid_density>1000</fluid_density><namespace>sub_ballast_3</namespace></plugin>
    <plugin filename="gz-sim-buoyancy-engine-system" name="gz::sim::systems::BuoyancyEngine"><link_name>ballast_4</link_name><min_volume>0.0</min_volume><max_volume>0.015</max_volume><neutral_volume>0.0075</neutral_volume><default_volume>0.0075</default_volume><max_inflation_rate>0.001</max_inflation_rate><fluid_density>1000</fluid_density><namespace>sub_ballast_4</namespace></plugin>

    <!-- ===== СИСТЕМНЫЕ ПЛАГИНЫ ===== -->
    <plugin filename="gz-sim-odometry-publisher-system" name="gz::sim::systems::OdometryPublisher">
      <odom_frame>world</odom_frame>
