    <!-- ===== БАЛЛАСТЫ ===== -->
    <link name="ballast_1"><pose>0.6625 0 -0.2 0 0 0</pose><inertial><mass>4.655</mass><inertia><ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz></inertia></inertial><visual name="b1_v"><geometry><box><size>0.375 0.05 0.05</size></box></geometry><material><ambient>0.80 0.20 0.20 1</ambient><diffuse>0.80 0.20 0.20 1</diffuse><specular>0.80 0.20 0.20 1</specular></material></visual><collision name="b1_c"><geometry><box><size>0.375 0.05 0.05</size></box></geometry></collision></link>
