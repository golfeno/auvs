      <inertial><mass>0.101</mass><inertia><ixx>0.0000592</ixx><iyy>0.0000592</iyy><izz>0.000117</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia></inertial>
      <visual name="rp_cyl"><geometry><cylinder><radius>0.0333</radius><length>0.03</length></cylinder></geometry><material><ambient>0.95 0.85 0.10 1</ambient><diffuse>0.95 0.85 0.10 1</diffuse><specular>0.95 0.85 0.10 1</specular></material></visual>
