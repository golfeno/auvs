<?xml version="1.0" ?>
<sdf version="1.6">
  <model name="submarine">
    <pose>0 0 0 0 0 0</pose>

    <!-- ===== КОРПУС ===== -->
    <link name="body">
      <pose>0.1 0 0 0 1.5707963267948966 0</pose>
      <inertial>
        <pose>0.2 0 0 0 0 0</pose>
        <mass>122.7</mass>
        <inertia>
          <ixx>1.64</ixx><iyy>18.33</iyy><izz>18.33</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
        <fluid_added_mass>
          <xx>5.8</xx><yy>116.0</yy><zz>116.0</zz>
          <pp>0.7</pp><qq>3.7</qq><rr>3.7</rr>
        </fluid_added_mass>
      </inertial>
      <visual name="body_visual">
        <geometry><cylinder><radius>0.17</radius><length>1.5</length></cylinder></geometry>
        <material><ambient>0.15 0.45 0.75 1</ambient><diffuse>0.15 0.45 0.75 1</diffuse><specular>0.15 0.45 0.75 1</specular></material>
      </visual>
      <collision name="body_collision">
        <geometry><cylinder><radius>0.17</radius><length>1.5</length></cylinder></geometry>
      </collision>
      <sensor name="imu_sensor" type="imu">
        <always_on>1</always_on><update_rate>100</update_rate>
        <topic>/model/submarine/imu</topic>
      </sensor>
      <sensor name="pressure_sensor" type="air_pressure">
        <always_on>1</always_on><update_rate>50</update_rate>
        <topic>/sub_press</topic>
      </sensor>
      <!-- ===== СОНАР — маркер позиции (визуал, без коллизии) ===== -->
      <visual name="sonar_marker">
        <pose>0.8 0 0 0 0 0</pose>
        <geometry><sphere><radius>0.06</radius></sphere></geometry>
        <material><ambient>1.0 0.1 0.8 1</ambient><diffuse>1.0 0.1 0.8 1</diffuse><specular>1.0 0.1 0.8 1</specular></material>
      </visual>

      <!-- ===== МАГНИТОМЕТР (абсолютный курс) ===== -->
      <sensor name="mag_sensor" type="magnetometer">
        <always_on>1</always_on><update_rate>50</update_rate>
        <topic>/model/submarine/magnetometer</topic>
      </sensor>
      <!-- ===== АЛЬТИМЕТР: эхолот ВНИЗ (высота над дном) ===== -->
      <sensor name="altimeter_sensor" type="gpu_lidar">
        <pose>0.17 0 0 0 0 0</pose>
        <always_on>1</always_on><update_rate>10</update_rate>
        <topic>/model/submarine/altimeter</topic>
        <lidar>
          <scan><horizontal><samples>1</samples><resolution>1</resolution>
            <min_angle>0</min_angle><max_angle>0</max_angle></horizontal></scan>
          <range><min>0.3</min><max>100.0</max><resolution>0.01</resolution></range>
        </lidar>
      </sensor>
      <!-- ===== СОНАР: эхолот ВПЕРЁД (препятствия) ===== -->
      <sensor name="sonar_sensor" type="gpu_lidar">
        <pose>0.8 0 0 0 -1.5707963 0</pose>
        <always_on>1</always_on><update_rate>10</update_rate>
        <topic>/model/submarine/sonar</topic>
        <gz_frame_id>submarine/body/sonar_sensor</gz_frame_id>
        <lidar>
          <scan>
            <horizontal><samples>16</samples><resolution>1</resolution>
              <min_angle>-0.349</min_angle><max_angle>0.349</max_angle></horizontal>
            <vertical><samples>16</samples><resolution>1</resolution>
              <min_angle>-0.349</min_angle><max_angle>0.349</max_angle></vertical>
          </scan>
          <range><min>0.5</min><max>50.0</max><resolution>0.01</resolution></range>
        </lidar>
      </sensor>
    </link>

    <!-- ===== ЛЕВЫЙ ПРОПЕЛЛЕР ===== -->
    <link name="left_propeller">
      <pose>0 0.2833333 0 0 1.5708 0</pose>
      <inertial>
        <mass>0.101</mass>
        <inertia><ixx>0.0000592</ixx><iyy>0.0000592</iyy><izz>0.000117</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="lp_cyl"><geometry><cylinder><radius>0.0333</radius><length>0.03</length></cylinder></geometry><material><ambient>0.95 0.85 0.10 1</ambient><diffuse>0.95 0.85 0.10 1</diffuse><specular>0.95 0.85 0.10 1</specular></material></visual>
      <visual name="lp_b1"><pose>0.057 0 0 -0.349066 0 0</pose><geometry><box><size>0.1 0.05 0.01</size></box></geometry><material><ambient>0.95 0.85 0.10 1</ambient><diffuse>0.95 0.85 0.10 1</diffuse><specular>0.95 0.85 0.10 1</specular></material></visual>
      <visual name="lp_b2"><pose>-0.057 0 0 0.349066 0 0</pose><geometry><box><size>0.1 0.05 0.01</size></box></geometry><material><ambient>0.95 0.85 0.10 1</ambient><diffuse>0.95 0.85 0.10 1</diffuse><specular>0.95 0.85 0.10 1</specular></material></visual>
      <visual name="lp_b3"><pose>0 0.057 0 0 -0.349066 0</pose><geometry><box><size>0.05 0.1 0.01</size></box></geometry><material><ambient>0.95 0.85 0.10 1</ambient><diffuse>0.95 0.85 0.10 1</diffuse><specular>0.95 0.85 0.10 1</specular></material></visual>
      <visual name="lp_b4"><pose>0 -0.057 0 0 0.349066 0</pose><geometry><box><size>0.05 0.1 0.01</size></box></geometry><material><ambient>0.95 0.85 0.10 1</ambient><diffuse>0.95 0.85 0.10 1</diffuse><specular>0.95 0.85 0.10 1</specular></material></visual>
      <collision name="lp_c1"><pose>0.057 0 0 -0.349066 0 0</pose><geometry><box><size>0.1 0.05 0.01</size></box></geometry></collision>
      <collision name="lp_c2"><pose>-0.057 0 0 0.349066 0 0</pose><geometry><box><size>0.1 0.05 0.01</size></box></geometry></collision>
      <collision name="lp_c3"><pose>0 0.057 0 0 -0.349066 0</pose><geometry><box><size>0.05 0.1 0.01</size></box></geometry></collision>
      <collision name="lp_c4"><pose>0 -0.057 0 0 0.349066 0</pose><geometry><box><size>0.05 0.1 0.01</size></box></geometry></collision>
    </link>
    <joint name="left_propeller_joint" type="revolute">
      <parent>body</parent><child>left_propeller</child>
      <axis><xyz>1 0 0</xyz><use_parent_model_frame>1</use_parent_model_frame>
        <limit><lower>-1e12</lower><upper>1e12</upper></limit>
        <dynamics><damping>0.5</damping></dynamics>
      </axis>
    </joint>
    <plugin filename="gz-sim-apply-joint-force-system" name="gz::sim::systems::ApplyJointForce">
      <joint_name>left_propeller_joint</joint_name>
    </plugin>
    <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag"><air_density>1000</air_density><cla>1.2535816618911175</cla><cla_stall>-1.4326647564469914</cla_stall><cda>0.02</cda><cda_stall>1.4326647564469914</cda_stall><alpha_stall>1.396</alpha_stall><area>0.007677</area><upward>0 -0.7071067811865476 -0.7071067811865475</upward><forward>0 -0.7071067811865475 0.7071067811865476</forward><link_name>left_propeller</link_name><cp>0.05833 0 0</cp></plugin>
    <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag"><air_density>1000</air_density><cla>1.2535816618911175</cla><cla_stall>-1.4326647564469914</cla_stall><cda>0.02</cda><cda_stall>1.4326647564469914</cda_stall><alpha_stall>1.396</alpha_stall><area>0.007677</area><upward>-0.7071067811865475 0 -0.7071067811865476</upward><forward>-0.7071067811865476 0 0.7071067811865475</forward><link_name>left_propeller</link_name><cp>0 -0.05833 0</cp></plugin>
    <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag"><air_density>1000</air_density><cla>1.2535816618911175</cla><cla_stall>-1.4326647564469914</cla_stall><cda>0.02</cda><cda_stall>1.4326647564469914</cda_stall><alpha_stall>1.396</alpha_stall><area>0.007677</area><upward>0 0.7071067811865475 -0.7071067811865476</upward><forward>0 0.7071067811865476 0.7071067811865475</forward><link_name>left_propeller</link_name><cp>-0.05833 0 0</cp></plugin>
    <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag"><air_density>1000</air_density><cla>1.2535816618911175</cla><cla_stall>-1.4326647564469914</cla_stall><cda>0.02</cda><cda_stall>1.4326647564469914</cda_stall><alpha_stall>1.396</alpha_stall><area>0.007677</area><upward>0.7071067811865476 0 -0.7071067811865475</upward><forward>0.7071067811865475 0 0.7071067811865476</forward><link_name>left_propeller</link_name><cp>0 0.05833 0</cp></plugin>

    <!-- ===== ПРАВЫЙ ПРОПЕЛЛЕР ===== -->
