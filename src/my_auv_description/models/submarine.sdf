    <!-- ===== НОСОВЫЕ ГОРИЗОНТАЛЬНЫЕ РУЛИ (зеркально кормовых) ===== -->

    <!-- Носовой правый руль -->
    <link name="horizontal_rudder_front_right">
      <pose>0.5 -0.27 0 0 0 0</pose>
      <inertial>
        <mass>0.02315</mass>
        <inertia><ixx>0.00000129</ixx><iyy>0.00000129</iyy><izz>0.00000129</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="hfrr_v">
        <geometry><box><size>0.1 0.2 0.005</size></box></geometry>
        <material><ambient>0.20 0.70 0.30 1</ambient><diffuse>0.20 0.70 0.30 1</diffuse><specular>0.20 0.70 0.30 1</specular></material>
      </visual>
      <collision name="hfrr_c">
        <geometry><box><size>0.1 0.2 0.005</size></box></geometry>
      </collision>
    </link>
    <joint name="horizontal_rudder_front_right_joint" type="revolute">
      <parent>body</parent><child>horizontal_rudder_front_right</child>
      <axis>
        <xyz>0 -1 0</xyz>
        <limit><lower>-0.785</lower><upper>0.785</upper><effort>10</effort><velocity>1.0</velocity></limit>
        <dynamics><damping>10.0</damping></dynamics>
      </axis>
    </joint>
    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <joint_name>horizontal_rudder_front_right_joint</joint_name>
      <topic>/model/submarine/joint/horizontal_rudder_front_right/cmd_position</topic>
      <p_gain>10</p_gain>
    </plugin>
    <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag">
      <air_density>1000</air_density>
      <link_name>horizontal_rudder_front_right</link_name>
      <area>0.014</area><cla>2.5</cla><cla_stall>-0.5</cla_stall>
      <cda>0.5</cda><cda_stall>1.5</cda_stall>
      <alpha_stall>1.2</alpha_stall><a0>0</a0>
      <upward>0 0 1</upward><forward>1 0 0</forward>
      <cp>0 0 0</cp>
    </plugin>

    <!-- Носовой левый руль -->
    <link name="horizontal_rudder_front_left">
      <pose>0.5 0.27 0 0 0 0</pose>
      <inertial>
        <mass>0.02315</mass>
        <inertia><ixx>0.00000129</ixx><iyy>0.00000129</iyy><izz>0.00000129</izz>
